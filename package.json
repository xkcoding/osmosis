{
  "name": "osmosis",
  "version": "0.1.0",
  "description": "GitHub Actions 驱动的多源内容订阅聚合器",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "fetch": "tsx src/index.ts fetch",
    "summarize": "tsx src/index.ts summarize",
    "notify": "tsx src/index.ts notify",
    "try-summary": "tsx scripts/try-summary.ts",
    "build": "tsup src/index.ts --format esm --target node20 --clean",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "ai": "^4.0.0",
    "fast-xml-parser": "^4.5.0",
    "node-html-markdown": "^1.3.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  }
}
